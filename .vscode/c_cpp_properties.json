{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "/usr/include/**",                  // 系统头文件
                "${workspaceFolder}/**",
                "/opt/ros/humble/include/**",
                "${workspaceFolder}/install/include/**", // 编译后的头文件
            ],
            "defines": [],
            "compilerPath": "/usr/bin/gcc",  // 建议改为gcc
            "cStandard": "c17",
            "cppStandard": "c++17",  // ROS2 Humble推荐C++17
            "intelliSenseMode": "linux-clang-x64"
        }
    ],
    "version": 4
}