{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) 附加到ROS2节点",
            "type": "cppdbg",
            "request": "attach",
            "program": "${workspaceFolder}/install/agv_bridge_v2/lib/agv_bridge_v2/agv_bridge_node",
            "processId": "${command:pickProcess}",
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}